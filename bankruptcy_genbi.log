            COUNT(*) as [Conversions],
            ROUND(COUNT(*) * 100.0 / (SELECT COUNT(*) FROM uploaded_data WHERE original_chapter != chapter AND original_chapter IS NOT NULL AND original_chapter != '' AND 1=1), 1) as [% of Total Conversions],
            ROUND(AVG(CAST(COALESCE(match_score, 0) AS FLOAT)), 1) as [Avg Risk Score]
        FROM uploaded_data
        WHERE original_chapter != chapter AND original_chapter IS NOT NULL AND original_chapter != '' AND 1=1
        GROUP BY original_chapter, chapter
        ORDER BY [Conversions] DESC
